# ============================================
# 微创AI带货视频工坊 — 后端环境配置模板
# 复制此文件为 .env 并填写实际值
# ============================================

# ----- 数据库 (MySQL 8.0) -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=shipin_user
DB_PASSWORD=your_db_password_here
DB_NAME=shipin_gongfang

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- API Key 加密密钥 (必须32字节) -----
# 生成方式: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=change-me-to-a-random-32byte-key!!

# ----- 本地存储路径 -----
STORAGE_UPLOAD_PATH=../storage/uploads
STORAGE_OUTPUT_PATH=../storage/outputs

# ----- AI 平台 API 地址 -----
OPENAI_BASE_URL=https://api.openai.com/v1
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ----- JWT 签名密钥 -----
JWT_SECRET=change-me-to-a-random-secret-string
