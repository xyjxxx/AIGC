# ============================================
# 微创AI带货视频工坊 — 后端环境配置
# 生成日期：2026-07-01
# ============================================

# ----- 开发模式 -----
# SQLite 模式（无需 Docker，开箱即用）
# 生产环境设为 false，改用下方 MySQL 配置
USE_SQLITE=true

# ----- 数据库 (MySQL 8.0，USE_SQLITE=false 时生效) -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=shipin_user
DB_PASSWORD=shipin_pass_2024
DB_NAME=shipin_gongfang

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- API Key 加密密钥 (32字节) -----
# 生产环境请更换为随机32字节字符串
ENCRYPTION_KEY=shipin-gongfang-prod-32byte-key!

# ----- 本地存储路径 -----
STORAGE_UPLOAD_PATH=../storage/uploads
STORAGE_OUTPUT_PATH=../storage/outputs

# ----- AI 平台 API 地址 -----
# OpenAI (用户自带 API Key)
OPENAI_BASE_URL=https://api.openai.com/v1
# 字节豆包 (用户自带 API Key)
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ----- JWT 密钥 -----
JWT_SECRET=shipin-gongfang-jwt-secret-2024
